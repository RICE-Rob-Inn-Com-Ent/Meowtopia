{
  "name": "cat-house-caffe",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "babel": {
    "presets": [
      "@babel/preset-env",
      "@babel/preset-react",
      "@babel/preset-typescript"
    ],
    "plugins": [
      [
        "@babel/plugin-transform-react-jsx",
        {
          "throwIfNamespace": false
        }
      ]
    ]
  },
  "postcss": {
    "plugins": {
      "tailwindcss": {},
      "autoprefixer": {}
    }
  },
  "dependencies": {
    "axios": "^1.9.0",
    "framer-motion": "^12.12.2",
    "openai": "^4.98.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.1"
  },
  "scripts": {
    "dev:user": "webpack serve --config webpack/webpack.user.config.js --mode development",
    "dev:admin": "webpack serve --config webpack/webpack.admin.config.js --mode development",
    "dev:webpack": "concurrently -n USER,ADMIN -c cyan,magenta \"yarn dev:user\" \"yarn dev:admin\"",
    "dev:django": "poetry run python src/manage.py runserver 0.0.0.0:3000",
    "dev": "concurrently -n WEBPACK,DJANGO -c blue,green \"yarn dev:webpack\" \"yarn dev:django\"",
    "webpack": "webpack",
    "build:user": "webpack --config webpack/webpack.user.config.js --mode production",
    "build:admin": "webpack --config webpack/webpack.admin.config.js --mode production",
    "build": "webpack --mode production"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@iconify/react": "^6.0.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/line-clamp": "^0.4.4",
    "@tailwindcss/postcss": "^4.1.8",
    "@tailwindcss/typography": "^0.5.16",
    "@types/less": "^3.0.8",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@types/ws": "^8.18.1",
    "@types/yaml": "^1.9.7",
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "@typescript-eslint/parser": "^8.33.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "html-webpack-plugin": "^5.6.3",
    "mini-css-extract-plugin": "^2.9.2",
    "open": "^10.1.2",
    "openapi-typescript-codegen": "^0.29.0",
    "postcss": "^8.5.3",
    "postcss-loader": "^8.1.1",
    "prism-react-renderer": "^2.4.1",
    "style-loader": "^4.0.0",
    "tailwind-scrollbar": "^4.0.2",
    "tailwindcss": "^4.1.7",
    "tailwindcss-children": "^2.1.0",
    "tailwindcss-fluid-type": "^2.0.7",
    "tailwindcss-logical": "^4.0.0",
    "tailwindcss-scroll-snap": "^1.1.0",
    "tailwindcss-textshadow": "^2.1.3",
    "ts-loader": "^9.5.2",
    "typescript": "^5.8.3",
    "webpack": "^5.99.9",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.1",
    "webpack-merge": "^6.0.1"
  },
  "packageManager": "yarn@4.9.1"
}
